{
  "name": "sentrovia",
  "version": "0.1.1",
  "description": "Sentrovia is a verification-aware monitoring platform for HTTP, TCP, and PostgreSQL uptime checks.",
  "private": true,
  "homepage": "https://github.com/febroine/sentrovia-monitoring",
  "bugs": {
    "url": "https://github.com/febroine/sentrovia-monitoring/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/febroine/sentrovia-monitoring.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "docker:web": "node scripts/bootstrap-runtime.mjs web",
    "docker:worker": "node scripts/bootstrap-runtime.mjs worker",
    "worker:dev": "tsx watch src/worker/runner.ts",
    "worker:start": "tsx src/worker/runner.ts",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:bootstrap": "drizzle-kit push --force"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@next/env": "^16.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
