# PostgreSQL connection. Prefer individual parts for examples; DATABASE_URL takes priority when set.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example-postgres-password-change-me
POSTGRES_DB=uptimemonitoring
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DATABASE_URL=Use POSTGRES_* variables above for examples. Set your real database URL in .env if needed.

APP_URL=http://localhost:3000
# APP_UPDATE_REPO=owner/repository
AUTH_SECRET=example-auth-secret-change-me-32-characters-minimum
AUTH_TRUST_PROXY_HEADERS=false
APP_ENCRYPTION_SECRET=example-encryption-secret-change-me-32-characters-minimum

WORKER_CONCURRENCY=20
WORKER_POLL_INTERVAL_MS=10000
# Pause checks and outbound worker tasks only when every canary is unreachable.
WORKER_CONNECTIVITY_CHECK_ENABLED=true
WORKER_CONNECTIVITY_TIMEOUT_MS=5000
# WORKER_CONNECTIVITY_TARGETS=https://www.google.com/generate_204,https://www.cloudflare.com/cdn-cgi/trace,https://www.msftconnecttest.com/connecttest.txt
MONITOR_ALLOW_PRIVATE_TARGETS=true
WORKER_AUTO_START=true
DISABLE_EMBEDDED_WORKER_SPAWN=true
